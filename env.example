# =============================================================================
# Jade Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys / secrets.
# Do NOT commit .env to git.
# Or export these variables in your shell before running.

# =============================================================================
# LLM Configuration
# =============================================================================

# LLM client type: openai, azure, or custom
LLM_CLIENT_TYPE=openai

# Model name
MODEL_NAME=your-model-name

# OpenAI API (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key

# Custom endpoint (used by configs when client_type: custom)
LLM_MODEL_NAME=your-llm-model-name
LLM_CUSTOM_API_VERSION=your-api-version
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_ENDPOINT=https://your-custom-endpoint.com
LLM_CUSTOM_HEADERS=your-custom-headers

# =============================================================================
# GenAI Configuration
# =============================================================================
# Used when agent_type: genai or config uses genai.*
GENAI_MODEL_NAME=your-model-name
GENAI_API_VERSION=your-api-version
GENAI_API_KEY=your-genai-api-key
GENAI_BASE_URL=https://your-genai-base-url.com
GENAI_CUSTOM_HEADERS=your-custom-headers


# =============================================================================
# Tool API Keys
# =============================================================================
# OpenRouter api key
OPENROUTER_API_KEY=your-openrouter-api-key

# SerpApi for web search (https://serper.dev/)
SERPAPI_KEY=your-serpapi-key

# Jina API for web scraping (https://jina.ai/reader/)
JINA_API_KEY=your-jina-api-key

# =============================================================================
# Agent Configuration
# =============================================================================

# Maximum iterations per verification item
AGENT_MAX_ITERATIONS=15

# Enable verbose output
AGENT_VERBOSE=true

